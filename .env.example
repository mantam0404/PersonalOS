VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# OAuth uses Google Identity Services popup — configure JavaScript origins, not redirect URIs.
# Production value is in .env.production (used by CI / GitHub Pages build).
# Local dev: copy this file to .env and paste your Client ID.

# Obsidian Bridge (local vault reader for Wiki sync)
# Run: npm run bridge
VITE_OBSIDIAN_BRIDGE_URL=http://localhost:8787
# Bridge env (server-side): OBSIDIAN_BRIDGE_PORT, OBSIDIAN_BRIDGE_API_KEY, CAPTURE_TOKEN
# Dev proxy alternative: http://localhost:5173/obsidian-bridge

# LLM API (optional — voice actions, classify, chat with notes)
# VITE_LLM_API_URL=http://localhost:3000/api/llm
